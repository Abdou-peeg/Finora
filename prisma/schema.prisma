// Finora ERP SaaS — Multi-tenant schema (PostgreSQL / Supabase)
// Plan comptable OHADA — contexte Sénégal

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT & AUTH
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  legalName String?
  siret     String?
  currency  String   @default("XOF")
  subscriptionStatus String @default("active")
  subscriptionExpiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  products        Product[]
  customers       Customer[]
  suppliers       Supplier[]
  sales           Sale[]
  purchases       Purchase[]
  invoices        Invoice[]
  cashEntries     CashEntry[]
  journalEntries  JournalEntry[]
  stockMovements  StockMovement[]
  auditLogs       AuditLog[]
  accounts        Account[]
  companySettings CompanySettings?
  quotes          Quote[]
  purchaseOrders  PurchaseOrder[]
  deliveryNotes   DeliveryNote[]
  
  // HR Module
  employees       Employee[]
  absences        Absence[]
  delays          Delay[]
  salaryLoans     SalaryLoan[]
  payrolls        Payroll[]
}

model User {
  id            String    @id @default(cuid())
  tenantId      String
  email         String    @unique
  name          String
  passwordHash  String
  role          UserRole  @default(VENDEUR)
  active        Boolean   @default(true)
  isSuperAdmin  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]
  
  // HR Module relations
  employee         Employee?
  approvedAbsences Absence[]    @relation("ApprovedAbsences")
  recordedDelays   Delay[]      @relation("RecordedDelays")
  approvedLoans    SalaryLoan[] @relation("ApprovedLoans")
  generatedPayrolls Payroll[]   @relation("GeneratedPayrolls")

  @@index([tenantId])
}

enum UserRole {
  ADMIN
  COMPTABLE
  VENDEUR
  STOCK_MANAGER
  HR_MANAGER
}

// ─────────────────────────────────────────────────────────────────────────────
// HR MODULE
// ─────────────────────────────────────────────────────────────────────────────

model Employee {
  id              String    @id @default(cuid())
  tenantId        String
  userId          String?   @unique
  firstName       String
  lastName        String
  email           String?
  phone           String?
  address         String?
  dateOfBirth     DateTime?
  hireDate        DateTime
  jobTitle        String?
  department      String?
  baseSalary      Decimal   @db.Decimal(14, 2)
  bankAccount     String?
  socialSecurityNum String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  absences        Absence[]
  delays          Delay[]
  salaryLoans     SalaryLoan[]
  payrolls        Payroll[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([userId])
}

model Absence {
  id              String    @id @default(cuid())
  tenantId        String
  employeeId      String
  startDate       DateTime
  endDate         DateTime
  type            AbsenceType
  reason          String?
  status          AbsenceStatus @default(PENDING)
  approvedById    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approvedBy      User?     @relation(name: "ApprovedAbsences", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([employeeId])
  @@index([approvedById])
}

enum AbsenceType {
  PAID_LEAVE
  SICK_LEAVE
  UNPAID_LEAVE
  MATERNITY_LEAVE
  PATERNITY_LEAVE
  OTHER
}

enum AbsenceStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Delay {
  id              String    @id @default(cuid())
  tenantId        String
  employeeId      String
  date            DateTime
  timeInMinutes   Int
  reason          String?
  recordedById    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  recordedBy      User?     @relation(name: "RecordedDelays", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([employeeId])
  @@index([recordedById])
}

model SalaryLoan {
  id              String    @id @default(cuid())
  tenantId        String
  employeeId      String
  amount          Decimal   @db.Decimal(14, 2)
  interestRate    Decimal?  @db.Decimal(5, 2) @default(0.00)
  startDate       DateTime
  endDate         DateTime?
  monthlyDeduction Decimal? @db.Decimal(14, 2)
  status          LoanStatus @default(PENDING)
  approvedById    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approvedBy      User?     @relation(name: "ApprovedLoans", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([employeeId])
  @@index([approvedById])
}

enum LoanStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
  PARTIALLY_PAID
}

model Payroll {
  id              String    @id @default(cuid())
  tenantId        String
  employeeId      String
  payPeriodStart  DateTime
  payPeriodEnd    DateTime
  grossSalary     Decimal   @db.Decimal(14, 2)
  netSalary       Decimal   @db.Decimal(14, 2)
  deductions      Decimal   @db.Decimal(14, 2)
  bonuses         Decimal   @db.Decimal(14, 2) @default(0)
  taxes           Decimal   @db.Decimal(14, 2)
  status          PayrollStatus @default(DRAFT)
  generatedById   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  generatedBy     User?     @relation(name: "GeneratedPayrolls", fields: [generatedById], references: [id], onDelete: SetNull)

  @@unique([tenantId, employeeId, payPeriodStart, payPeriodEnd])
  @@index([tenantId])
  @@index([employeeId])
  @@index([generatedById])
}

enum PayrollStatus {
  DRAFT
  GENERATED
  APPROVED
  PAID
  CANCELLED
}

// ─────────────────────────────────────────────────────────────────────────────
// COMPANY SETTINGS — infos légales, logo, signature
// ─────────────────────────────────────────────────────────────────────────────

model CompanySettings {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  // Identité légale (Sénégal)
  legalName     String
  legalForm     String?  // SARL, SA, EURL, Individual...
  rc            String?  // Registre du Commerce
  ninea         String?  // NINEA Sénégal
  nCompte       String?  // N° compte contribuable
  capital       Decimal? @db.Decimal(14, 2)
  // Coordonnées
  address       String?
  city          String?
  postalCode    String?  // BP au Sénégal
  country       String   @default("Sénégal")
  phone         String?
  email         String?
  website       String?
  // Branding
  logo          String?  // base64 data URL
  signature     String?  // base64 data URL
  footerNote    String?  // mention pied de page (ex: "Cachet et signature")
  // Banque
  bankName      String?
  bankIban      String?
  bankBic       String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// ACCOUNTING (OHADA)
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  label     String
  type      AccountType
  createdAt DateTime @default(now())

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  journalLines  JournalEntryLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model JournalEntry {
  id          String   @id @default(cuid())
  tenantId    String
  reference   String
  description String
  date        DateTime @default(now())
  source      JournalSource
  sourceId    String?
  createdAt   DateTime @default(now())

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines       JournalEntryLine[]

  @@index([tenantId])
  @@index([tenantId, date])
}

enum JournalSource {
  SALE
  PURCHASE
  INVOICE
  CASH
  MANUAL
  PAYROLL
}

model JournalEntryLine {
  id             String   @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal  @db.Decimal(14, 2)
  credit         Decimal  @db.Decimal(14, 2)

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@index([accountId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCTS & STOCK
// ─────────────────────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  sku         String
  name        String
  description String?
  imageUrl    String?
  category    String?
  unit        String   @default("pièce")
  salePrice   Decimal  @db.Decimal(14, 2)
  costPrice   Decimal  @db.Decimal(14, 2)
  taxRate     Decimal  @db.Decimal(5, 2) @default(18.00)
  stockQty    Decimal  @db.Decimal(14, 2) @default(0)
  minStock    Decimal  @db.Decimal(14, 2) @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  saleItems      SaleItem[]
  purchaseItems  PurchaseItem[]
  stockMovements StockMovement[]
  quoteItems     QuoteItem[]
  poItems        PurchaseOrderItem[]
  dnItems        DeliveryNoteItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
}

model StockMovement {
  id         String      @id @default(cuid())
  tenantId   String
  productId  String
  type       MovementType
  qty        Decimal     @db.Decimal(14, 2)
  reference  String
  createdAt  DateTime    @default(now())

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productId])
}

enum MovementType {
  IN
  OUT
  ADJ
}

// ─────────────────────────────────────────────────────────────────────────────
// PARTIES — Customers & Suppliers
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id          String   @id @default(cuid())
  tenantId    String
  code        String
  name        String
  email       String?
  phone       String?
  address     String?
  city        String?
  country     String?
  taxId       String?
  creditLimit Decimal? @db.Decimal(14, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales     Sale[]
  quotes    Quote[]
  deliveryNotes DeliveryNote[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Supplier {
  id         String   @id @default(cuid())
  tenantId   String
  code       String
  name       String
  email      String?
  phone      String?
  address    String?
  city       String?
  country    String?
  taxId      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchases  Purchase[]
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SALES & PURCHASES
// ─────────────────────────────────────────────────────────────────────────────

model Sale {
  id           String     @id @default(cuid())
  tenantId     String
  reference    String
  customerId   String
  userId       String?
  quoteId      String?   @unique
  date         DateTime   @default(now())
  status       SaleStatus @default(DRAFT)
  subtotal     Decimal    @db.Decimal(14, 2)
  taxTotal     Decimal    @db.Decimal(14, 2)
  total        Decimal    @db.Decimal(14, 2)
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer     Customer    @relation(fields: [customerId], references: [id])
  items        SaleItem[]
  invoice      Invoice?
  deliveryNotes DeliveryNote[]
  quote        Quote?       @relation(fields: [quoteId], references: [id])

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@index([customerId])
}

enum SaleStatus {
  DRAFT
  CONFIRMED
  INVOICED
  PAID
  CANCELLED
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  productId String
  qty       Decimal @db.Decimal(14, 2)
  unitPrice Decimal @db.Decimal(14, 2)
  taxRate   Decimal @db.Decimal(5, 2)
  lineTotal Decimal @db.Decimal(14, 2)

  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([saleId])
}

model Purchase {
  id           String          @id @default(cuid())
  tenantId     String
  reference    String
  supplierId   String
  userId       String?
  purchaseOrderId String? @unique
  date         DateTime        @default(now())
  status       PurchaseStatus  @default(DRAFT)
  subtotal     Decimal         @db.Decimal(14, 2)
  taxTotal     Decimal         @db.Decimal(14, 2)
  total        Decimal         @db.Decimal(14, 2)
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier     Supplier        @relation(fields: [supplierId], references: [id])
  items        PurchaseItem[]
  invoice      Invoice?
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@index([supplierId])
}

enum PurchaseStatus {
  DRAFT
  CONFIRMED
  INVOICED
  PAID
  CANCELLED
}

model PurchaseItem {
  id         String  @id @default(cuid())
  purchaseId String
  productId  String
  qty        Decimal @db.Decimal(14, 2)
  unitPrice  Decimal @db.Decimal(14, 2)
  taxRate    Decimal @db.Decimal(5, 2)
  lineTotal  Decimal @db.Decimal(14, 2)

  purchase  Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@index([purchaseId])
}

// ─────────────────────────────────────────────────────────────────────────────
// INVOICING
// ─────────────────────────────────────────────────────────────────────────────

model Invoice {
  id           String        @id @default(cuid())
  tenantId     String
  number       String
  type         InvoiceType
  partyType    PartyType
  partyId      String
  partyName    String
  saleId       String?       @unique
  purchaseId   String?       @unique
  issueDate    DateTime      @default(now())
  dueDate      DateTime?
  subtotal     Decimal       @db.Decimal(14, 2)
  taxTotal     Decimal       @db.Decimal(14, 2)
  total        Decimal       @db.Decimal(14, 2)
  paidAmount   Decimal       @db.Decimal(14, 2) @default(0)
  status       InvoiceStatus @default(UNPAID)
  createdAt    DateTime      @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale         Sale?         @relation(fields: [saleId], references: [id])
  purchase     Purchase?     @relation(fields: [purchaseId], references: [id])

  @@unique([tenantId, number])
  @@index([tenantId])
}

enum InvoiceType {
  CUSTOMER
  SUPPLIER
}

enum PartyType {
  CUSTOMER
  SUPPLIER
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  CANCELLED
}

// ─────────────────────────────────────────────────────────────────────────────
// QUOTES (DEVIS)
// ─────────────────────────────────────────────────────────────────────────────

model Quote {
  id           String      @id @default(cuid())
  tenantId     String
  number       String
  customerId   String
  userId       String?
  date         DateTime    @default(now())
  validUntil   DateTime?
  status       QuoteStatus @default(DRAFT)
  subtotal     Decimal     @db.Decimal(14, 2)
  taxTotal     Decimal     @db.Decimal(14, 2)
  total        Decimal     @db.Decimal(14, 2)
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer     Customer    @relation(fields: [customerId], references: [id])
  items        QuoteItem[]
  sale         Sale?

  @@unique([tenantId, number])
  @@index([tenantId])
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  REFUSED
  CONVERTED
}

model QuoteItem {
  id        String  @id @default(cuid())
  quoteId   String
  productId String
  qty       Decimal @db.Decimal(14, 2)
  unitPrice Decimal @db.Decimal(14, 2)
  taxRate   Decimal @db.Decimal(5, 2)
  lineTotal Decimal @db.Decimal(14, 2)

  quote     Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([quoteId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PURCHASE ORDERS (BONS DE COMMANDE)
// ─────────────────────────────────────────────────────────────────────────────

model PurchaseOrder {
  id           String              @id @default(cuid())
  tenantId     String
  number       String
  supplierId   String
  date         DateTime            @default(now())
  status       PurchaseOrderStatus @default(DRAFT)
  subtotal     Decimal             @db.Decimal(14, 2)
  taxTotal     Decimal             @db.Decimal(14, 2)
  total        Decimal             @db.Decimal(14, 2)
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  items        PurchaseOrderItem[]
  purchase     Purchase?

  @@unique([tenantId, number])
  @@index([tenantId])
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  RECEIVED
  CANCELLED
}

model PurchaseOrderItem {
  id         String  @id @default(cuid())
  purchaseOrderId String
  productId  String
  qty        Decimal @db.Decimal(14, 2)
  unitPrice  Decimal @db.Decimal(14, 2)
  taxRate    Decimal @db.Decimal(5, 2)
  lineTotal  Decimal @db.Decimal(14, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
}

// ─────────────────────────────────────────────────────────────────────────────
// DELIVERY NOTES (BONS DE LIVRAISON)
// ─────────────────────────────────────────────────────────────────────────────

model DeliveryNote {
  id           String   @id @default(cuid())
  tenantId     String
  number       String
  customerId   String
  saleId       String?
  userId       String?
  date         DateTime @default(now())
  status       DeliveryNoteStatus @default(DRAFT)
  notes        String?
  receivedBy   String?  // personne ayant réceptionné chez le client
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer     Customer @relation(fields: [customerId], references: [id])
  sale         Sale?    @relation(fields: [saleId], references: [id])
  items        DeliveryNoteItem[]

  @@unique([tenantId, number])
  @@index([tenantId])
}

enum DeliveryNoteStatus {
  DRAFT
  DELIVERED
  CANCELLED
}

model DeliveryNoteItem {
  id              String  @id @default(cuid())
  deliveryNoteId  String
  productId       String
  qty             Decimal @db.Decimal(14, 2)
  description     String?

  deliveryNote    DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  product         Product      @relation(fields: [productId], references: [id])

  @@index([deliveryNoteId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CASH & TREASURY (Caisse & Trésorerie)
// ─────────────────────────────────────────────────────────────────────────────

model CashEntry {
  id          String         @id @default(cuid())
  tenantId    String
  reference   String
  type        CashType
  amount      Decimal        @db.Decimal(14, 2)
  label       String
  source      CashSource
  sourceId    String?
  invoiceId   String?
  date        DateTime       @default(now())
  balanceAfter Decimal?       @db.Decimal(14, 2)
  createdAt   DateTime       @default(now())

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, date])
}

enum CashType {
  IN
  OUT
}

enum CashSource {
  SALE
  PURCHASE
  INVOICE_PAYMENT
  MANUAL
  PAYROLL
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  userName   String?
  action     String
  entity     String
  entityId   String?
  details    String?
  ip         String?
  createdAt  DateTime @default(now())

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, entity])
  @@index([createdAt])
}
